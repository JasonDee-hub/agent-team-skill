    },
    {
      "id": "high-risk-single-file-keeps-strict-path",
      "scenario": "A single-file authorization fix remains on the strict path because file count does not override security risk.",
      "prompt": "$agent-team 修复 src/auth.ts 中的权限绕过问题，只需要改一个文件。虽然范围小，但这是安全边界，请实现后安排独立审查。",
      "expected": {
        "agent_team_trigger": true,
        "execution_mode": "real_multi_agent",
        "handoff_mode": "full",
        "dispatch": {
          "roles": [
            "Kane",
            "Reed"
          ],
          "mode": "sequential",
          "order": [
            "Kane",
            "Reed"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "scoped_write",
          "roles": [
            "Kane"
          ],
          "write_paths": [
            "src/auth.ts"
          ]
        },
        "scope": {
          "read_paths": [
            "src/auth.ts"
          ],
          "write_paths": [
            "src/auth.ts"
          ],
          "external_actions": []
        },
        "outcome": "security_fix_with_independent_review",
        "invariants": [
          "high_risk_task_keeps_strict_handoff",
          "single_file_count_does_not_override_security_risk",
          "implementation_precedes_independent_review"
        ]
      }
    },
    {
      "id": "unknown-failure-orin-first",
      "scenario": "An unexplained failure starts with diagnosis rather than speculative implementation.",
