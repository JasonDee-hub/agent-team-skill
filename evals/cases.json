{
  "schema_version": 1,
  "description": "Forward-test cases for Agent Team routing, scheduling, and authority boundaries.",
  "vocabulary": {
    "dispatch.mode": [
      "none",
      "single",
      "sequential",
      "parallel"
    ],
    "write_authority.mode": [
      "read_only",
      "role_scoped",
      "blocked"
    ]
  },
  "cases": [
    {
      "id": "tiny-explicit-read-only",
      "scenario": "An explicitly invoked, tiny explanation is handled by the lead without dispatch.",
      "prompt": "$agent-team 用两句话解释一下这个项目里的 SKILL.md 是做什么的，不要修改任何文件。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [],
          "mode": "none",
          "order": [],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "lead_handles_directly",
        "invariants": [
          "tiny_task_does_not_require_subagent",
          "no_files_changed"
        ]
      }
    },
    {
      "id": "generic-single-subagent-no-trigger",
      "scenario": "A one-off request for a generic subagent does not activate Agent Team orchestration.",
      "prompt": "Please ask one generic subagent to summarize README.md and return the summary.",
      "expected": {
        "agent_team_trigger": false,
        "dispatch": {
          "roles": [],
          "mode": "none",
          "order": [],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "outside_agent_team",
        "invariants": [
          "generic_subagent_request_is_not_team_orchestration",
          "agent_team_roles_are_not_injected"
        ]
      }
    },
    {
      "id": "review-diff-reed-only",
      "scenario": "A focused diff review routes only to Reed and remains read-only.",
      "prompt": "$agent-team 请认真 review 当前 git diff，只报告 correctness、回归风险和缺失测试，不要修复。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Reed"
          ],
          "mode": "single",
          "order": [
            "Reed"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "review_report",
        "invariants": [
          "review_request_does_not_authorize_fixes",
          "findings_are_evidence_based"
        ]
      }
    },
    {
      "id": "clear-code-fix-kane-only",
      "scenario": "A clear implementation request routes to Kane without unnecessary specialists.",
      "prompt": "/agent-team 修复 src/cache.ts 中已经定位的过期时间单位错误，并补上对应单元测试。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Kane"
          ],
          "mode": "single",
          "order": [
            "Kane"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "role_scoped",
          "roles": [
            "Kane"
          ]
        },
        "outcome": "implemented_and_locally_tested",
        "invariants": [
          "product_code_writes_belong_to_kane",
          "scope_stays_on_located_bug"
        ]
      }
    },
    {
      "id": "unknown-failure-orin-first",
      "scenario": "An unexplained failure starts with diagnosis rather than speculative implementation.",
      "prompt": "$agent-team CI 偶发退出 137，本地无法复现，也不知道根因。先查明原因并给证据，不要直接改产品代码。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Orin"
          ],
          "mode": "single",
          "order": [
            "Orin:first"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "diagnosis_or_evidenced_handoff",
        "invariants": [
          "diagnosis_precedes_fix",
          "orin_has_no_implicit_product_write_authority"
        ]
      }
    },
    {
      "id": "feature-then-independent-qa",
      "scenario": "A feature implementation is completed by Kane and then independently verified by Vera.",
      "prompt": "$agent-team 实现导出 CSV 功能并补测试；实现完成后请安排独立 QA 按验收标准验证。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Kane",
            "Vera"
          ],
          "mode": "sequential",
          "order": [
            "Kane",
            "Vera"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "role_scoped",
          "roles": [
            "Kane"
          ]
        },
        "outcome": "implementation_with_independent_evidence",
        "invariants": [
          "vera_tests_after_implementation",
          "vera_does_not_rewrite_product_code_to_make_tests_pass"
        ]
      }
    },
    {
      "id": "ui-reproduction-lina-only",
      "scenario": "A browser UI reproduction routes to Lina and records evidence without source edits.",
      "prompt": "/agent-team 在浏览器里复现移动端结算页按钮被遮挡的问题，记录步骤、视口和截图，不要改代码。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Lina"
          ],
          "mode": "single",
          "order": [
            "Lina"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "ui_reproduction_evidence",
        "invariants": [
          "browser_reproduction_routes_to_lina",
          "evidence_includes_reproduction_context"
        ]
      }
    },
    {
      "id": "plan-only-no-writes",
      "scenario": "A substantial engineering plan may use Kane, but planning language grants no write authority.",
      "prompt": "$agent-team 只制定把认证模块拆成三个包的实施计划，列出依赖、迁移顺序和风险，先不要动代码。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Kane"
          ],
          "mode": "single",
          "order": [
            "Kane"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "implementation_plan_only",
        "invariants": [
          "plan_request_is_not_implementation_authority",
          "no_files_changed"
        ]
      }
    },
    {
      "id": "independent-read-only-parallel",
      "scenario": "Independent research and review streams may run concurrently when neither writes.",
      "prompt": "$agent-team 并行完成两件互不依赖的只读任务：Mira 调研依赖库升级风险，Reed 审查当前 diff；最后汇总，不要修改文件。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Mira",
            "Reed"
          ],
          "mode": "parallel",
          "order": [],
          "concurrent_groups": [
            [
              "Mira",
              "Reed"
            ]
          ]
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "merged_independent_reports",
        "invariants": [
          "only_independent_read_tasks_parallelize",
          "each_report_keeps_its_own_evidence"
        ]
      }
    },
    {
      "id": "overlapping-writers-serialize",
      "scenario": "Write subtasks that overlap on a path are serialized even when they could otherwise be split.",
      "prompt": "$agent-team 把路由改造拆成两个实现子任务，但两边都必须修改 src/router.ts 和生成 routes.json；请确保不会互相覆盖。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Kane"
          ],
          "mode": "sequential",
          "order": [
            "Kane:routing-core",
            "Kane:route-generation"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "role_scoped",
          "roles": [
            "Kane"
          ]
        },
        "outcome": "serialized_implementation",
        "invariants": [
          "overlapping_paths_never_have_concurrent_writers",
          "generated_artifacts_are_serialized",
          "single_writer_per_path"
        ]
      }
    },
    {
      "id": "missing-credentials-blocked",
      "scenario": "Missing credentials produce an explicit block rather than fabricated completion.",
      "prompt": "$agent-team Deploy this release to production. The required cloud credentials are not available in this environment.",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [],
          "mode": "none",
          "order": [],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "blocked",
          "roles": []
        },
        "outcome": "blocked",
        "invariants": [
          "known_blocker_does_not_require_dispatch",
          "blocked_by_names_missing_credentials",
          "no_fake_deployment_success",
          "no_secret_guessing_or_bypass"
        ]
      }
    },
    {
      "id": "short-domain-task-atlas-exemption",
      "scenario": "A short, low-risk out-of-domain task uses Atlas under the explicit short-task exemption.",
      "prompt": "$agent-team 帮我写一段 80 字以内的中文会议开场白，背景和语气已经明确，按短任务豁免直接完成。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Atlas"
          ],
          "mode": "single",
          "order": [
            "Atlas"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "atlas_domain_output",
        "invariants": [
          "short_task_exemption_is_recorded",
          "no_new_specialist_role_is_invented",
          "atlas_does_not_claim_domain_expert_identity"
        ]
      }
    },
    {
      "id": "high-risk-domain-grilling-then-atlas",
      "scenario": "A higher-risk out-of-domain deliverable requires domain grilling before Atlas drafts it.",
      "prompt": "$agent-team 起草一份将提交给伦理委员会的人体研究知情同意书。需求还很模糊，请先完成领域 grilling，再由通才整理初稿。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [
            "Atlas"
          ],
          "mode": "sequential",
          "order": [
            "domain_grilling",
            "Atlas"
          ],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "grilled_atlas_draft_or_blocked",
        "invariants": [
          "atlas_receives_grilling_consensus_before_drafting",
          "insufficient_or_conflicting_context_blocks_drafting",
          "no_new_specialist_role_is_invented",
          "domain_limit_is_disclosed"
        ]
      }
    }
  ]
}
