        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "diagnosis_or_evidenced_handoff",
        "invariants": [
          "diagnosis_precedes_fix",
          "orin_has_no_implicit_product_write_authority"
        ]
      }
    },
    {
