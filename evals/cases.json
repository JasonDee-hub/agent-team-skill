{
  "schema_version": 2,
  "description": "Forward-test cases for Agent Team routing, scheduling, authority, trust, and side-effect boundaries.",
  "vocabulary": {
    "dispatch.mode": [
      "none",
      "single",
      "sequential",
      "parallel"
    ],
    "write_authority.mode": [
      "read_only",
      "scoped_write"
    ],
    "execution_mode": [
      "any",
      "real_multi_agent",
      "single_agent_simulation"
    ]
  },
  "cases": [
    {
      "id": "tiny-explicit-read-only",
      "scenario": "An explicitly invoked, tiny explanation is handled by the lead without dispatch.",
      "prompt": "$agent-team 用两句话解释一下这个项目里的 SKILL.md 是做什么的，不要修改任何文件。",
      "expected": {
        "agent_team_trigger": true,
        "dispatch": {
          "roles": [],
          "mode": "none",
          "order": [],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "lead_handles_directly",
        "invariants": [
          "tiny_task_does_not_require_subagent",
          "no_files_changed"
        ]
      }
    },
    {
      "id": "generic-single-subagent-no-trigger",
      "scenario": "A one-off request for a generic subagent does not activate Agent Team orchestration.",
      "prompt": "Please ask one generic subagent to summarize README.md and return the summary.",
      "expected": {
        "agent_team_trigger": false,
        "dispatch": {
          "roles": [],
          "mode": "none",
          "order": [],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "read_only",
          "roles": []
        },
        "outcome": "outside_agent_team",
        "invariants": [
          "generic_subagent_request_is_not_team_orchestration",
          "agent_team_roles_are_not_injected"
        ]
      }
    },
    {
      "id": "low-risk-single-file-lead-fast-path",
      "scenario": "An explicitly authorized, low-risk single-file fix uses the lead fast path without specialist ceremony.",
      "prompt": "$agent-team 修复 src/format.ts 中已经定位的 trim 调用错误，只改这个文件。该改动不涉及安全、数据、依赖、CI、公共 API、生产或外部动作，并运行针对性测试。",
      "expected": {
        "agent_team_trigger": true,
        "lead_execution": true,
        "handoff_mode": "none",
        "dispatch": {
          "roles": [],
          "mode": "none",
          "order": [],
          "concurrent_groups": []
        },
        "write_authority": {
          "mode": "scoped_write",
          "lead": true,
          "roles": [],
          "write_paths": [
            "src/format.ts"
          ]
        },
        "scope": {
          "read_paths": [
            "src/format.ts"
          ],
          "write_paths": [
            "src/format.ts"
          ],
          "external_actions": []
        },
        "outcome": "lead_fast_path_change_verified",
        "invariants": [
          "low_risk_single_file_write_can_use_lead",
          "lead_fast_path_is_single_file_only",
          "lead_fast_path_has_no_external_actions",
          "fast_path_verification_is_disclosed_as_non_independent"
        ]
      }
    },
    {
      "id": "review-diff-reed-only",
      "scenario": "A focused diff review routes only to Reed and remains read-only.",
